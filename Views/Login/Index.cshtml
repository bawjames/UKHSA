@{
    ViewData["Title"] = "Login Page";
}

<div class="text-center">
    <br />
    <div class="login-container">
        <form>
            <h1 class="display-4" style="text-align:center;">Login</h1>
            <input class="input-box" type="text" placeholder="Email"/>
            <input class="input-box" type ="password" placeholder="Password" />
            <input type="radio" id="RememberMe"/>
            <label for="RememberMe">Remember Me</label>
            <br />
            <br />
            <button class="input-button" type="submit">Login</button>
        </form>
    </div>
</div>
