@{
  ViewData["Title"] = "Add Document Page";
}

<div class="text-center">
  <br />
  <div class="login-container">
    <h1 style="text-align:center; !important">Add New Dataset</h1>
    <br />
    <form action="/Admin/AddDataset" method="post">

    <h3>Dataset Name</h3>
    <input type="text" id="Title" class="input-box" required />

    <h3>Access Type</h3>
    <input type="radio" id="sensitive" name="AccessLevel" value=1 />
    <label for="sensitive">Sensitive</label>
    <input type="radio" id="non-sensitive" name="AccessLevel" value=0 />
    <label for="non-sensitive">Non-sensitive</label>

    <h3>Description</h3>
    <textarea rows="4" cols="41" id="Description"></textarea>
    
    <button class="input-button" type="submit" style="margin-top: 2em;">Add Dataset</button>
    </form>
  </div>
</div>